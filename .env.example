# ── Required — Paymob ──────────────────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_MOTO_INTEGRATION_ID=

# ── Required — Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/paymob_db

# ── Required — Auth (generate a strong random secret) ─────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Required — App URL (used for webhook callbacks) ───────────────────────────
APP_URL=https://your-domain.com

# ── Optional — GHL Webhook (will be auto-seeded into DB on first run) ─────────
# GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# ── Optional — Wallet payments ────────────────────────────────────────────────
PAYMOB_WALLET_INTEGRATION_ID=

# ── Optional — Subscription Plan IDs (from scripts/setup-plans.js) ────────────
PAYMOB_MONTHLY_PLAN_ID=
PAYMOB_YEARLY_PLAN_ID=
PAYMOB_WEEKLY_PLAN_ID=

# ── Optional — Defaults ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CURRENCY=EGP
MONTHLY_AMOUNT_CENTS=10000
YEARLY_AMOUNT_CENTS=100000

# ── Optional — CORS for embedded checkout ─────────────────────────────────────
# EMBED_ORIGINS=https://your-site.com,https://another-site.com
# Leave empty or * to allow all origins

# ── First-time Admin Setup (run: node scripts/seed-admin.js) ──────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
